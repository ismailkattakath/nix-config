{
  // nix-config devcontainer — now a PREBUILT image, not a features stack.
  //
  // The image (.devcontainer/Dockerfile) bakes in nix + the pre-warmed flake
  // devShell + claude-code + gh, so first `nix develop` is instant and there is
  // no per-create feature install. Built + published multi-arch to Docker Hub;
  // see .github/workflows (phase 2) — for now build locally with:
  //   docker buildx build --platform linux/arm64 -f .devcontainer/Dockerfile \
  //     -t nix-config-devcontainer:local --load .
  // and point "image" at the local tag to smoke-test.
  //
  // Phase 2 swaps the Dockerfile for a baseless dockerTools image; ONLY the
  // "image" tag below changes.
  "name": "nix-config (flake devShell — prebuilt)",
  "image": "docker.io/ismailkattakath/nix-config-devcontainer:latest",

  "workspaceFolder": "/workspaces/nix-config",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/nix-config,type=bind,consistency=cached",

  // The devShell closure is PREBUILT into the image. This re-runs the warm on
  // create — cheap (closure already cached) — and installs the real
  // .git/hooks/pre-commit against the bind-mounted workspace (the build-time
  // hook lived in a throwaway tree, see Dockerfile §3).
  "updateContentCommand": "nix develop --command true",

  // Replaces the claude-code-persistence feature: a named volume persists
  // ~/.claude (history/sessions/todos) across rebuilds. Uncomment the second
  // mount to also persist auth (~/.claude.json) — the feature did NOT by default,
  // so you re-login after a rebuild unless you opt in here.
  "mounts": [
    "source=claude-dir-${devcontainerId},target=/home/vscode/.claude,type=volume"
    // ,"source=claude-json-${devcontainerId},target=/home/vscode/.claude.json,type=volume"
  ],

  "containerEnv": {
    "NIXPKGS_ALLOW_UNFREE": "1"
  },

  "customizations": {
    "vscode": {
      // Installed into the container on create. The host only RECOMMENDS these
      // (see ../.vscode/extensions.json) — they need nix + the devShell to work,
      // which lives in this image, not on the nix-less host.
      "extensions": [
        "jnoortheen.nix-ide",
        "gruntfuggly.triggertaskonsave",
        "fuadpashayev.bottom-terminal",
        "Anthropic.claude-code",
        "shd101wyy.markdown-preview-enhanced"
      ],
      "settings": {
        // --- Nix language server (nix-ide → nixd) ---
        // nixd/nixfmt come from the devShell PATH. If nix-ide can't find them
        // outside an active `nix develop`, either add a global
        // `nix profile install nixpkgs#nixd nixpkgs#nixfmt-rfc-style` to the
        // Dockerfile or set absolute store paths here. (Verify in-container.)
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nixd",
        "nix.formatterPath": "nixfmt",
        "nix.serverSettings": {
          "nixd": {
            "formatting": { "command": ["nixfmt"] }
          }
        },

        // --- Format on save, nix-ide owns .nix files ---
        "editor.formatOnSave": true,
        "[nix]": {
          "editor.defaultFormatter": "jnoortheen.nix-ide"
        },

        // --- Live statix/deadnix diagnostics on save (Problems tab) ---
        // On .nix save, runs the "nix: lint" task (../.vscode/tasks.json), whose
        // problem matchers feed statix (anti-patterns) + deadnix (dead code) into
        // Problems — the gap nix-ide/nixd don't cover. Needs triggertaskonsave.
        "triggerTaskOnSave.on": true,
        "triggerTaskOnSave.showNotifications": false,
        "triggerTaskOnSave.tasks": {
          "nix: lint": ["**/*.nix"]
        },

        // --- Terminal profiles ---
        // claude-code is installed via nvm in the image, so the binary lives
        // under the nvm `current` symlink (current -> versions/node/<ver>) — NOT
        // a hardcoded version dir, so the path survives node bumps. Phase 2
        // (claude-code from nixpkgs) changes this to /bin/claude.
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          },
          "claude": {
            "path": "/usr/local/share/nvm/current/bin/claude",
            "args": ["--permission-mode", "bypassPermissions"],
            "icon": "claude",
            "color": "terminal.ansiYellow"
          }
        }
      }
    }
  },

  "remoteUser": "vscode"
}
