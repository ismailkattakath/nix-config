{
  // Editor settings for this flake, mirrored from .devcontainer/devcontainer.json
  // so opening the repo directly on the host (with the direnv extension loading
  // the devShell) gives the same nixd + format-on-save experience as the container.

  // --- Nix language server (nix-ide → nixd) ---
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd", // eval-aware LSP; provided by the flake devShell via direnv
  "nix.formatterPath": "nixfmt", // matches treefmt's Nix formatter (RFC 166)

  // nixd needs to know how to evaluate this flake for option/attr completion.
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      }
    }
  },

  // --- Format on save, nix-ide owns .nix files ---
  "editor.formatOnSave": true,
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  }
}
